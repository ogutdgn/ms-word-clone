{
  "name": "msword-clone",
  "productName": "Word",
  "version": "1.0.0",
  "description": "A faithful Microsoft Word desktop clone (UI, features, functionality) built with Electron.",
  "main": "./out/main/index.js",
  "author": "Word Clone Project",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite dev",
    "test:pm": "electron --user-data-dir=C:/tmp/wc-probe-profile --disable-http-cache . --probe-out=/tmp/wc-pm.json --shot-evalfile=scripts/test-suite-pm.js",
    "test:smoke": "electron --user-data-dir=C:/tmp/wc-probe-profile --disable-http-cache . --probe-out=/tmp/wc-smoke.json --shot-evalfile=scripts/smoke-pm.js",
    "test:roundtrip": "node scripts/test-roundtrip-pm.js",
    "test:roundtrip:paged": "node scripts/test-roundtrip-paged.js",
    "report:glyphgeom": "node scripts/paged-glyphgeom-validate.js",
    "test:bundle": "node scripts/check-overlay-bundle.js",
    "probe:ink:m5": "electron --user-data-dir=C:/tmp/wc-probe-profile --disable-http-cache . --probe-out=/tmp/wc-m5-ink.json --shot-evalfile=scripts/paged-export-m5-ink-probe.js",
    "probe:export:m5": "electron --user-data-dir=C:/tmp/wc-probe-profile --disable-http-cache . --probe-out=/tmp/wc-m5-ks.json --shot-evalfile=scripts/paged-export-m5-probe.js",
    "probe:coords": "electron --user-data-dir=C:/tmp/wc-probe-profile --disable-http-cache . --probe-out=/tmp/wc-coords.json --shot-evalfile=scripts/paged-coords-probe.js",
    "probe:pointer": "electron --user-data-dir=C:/tmp/wc-probe-profile --disable-http-cache . --probe-out=/tmp/wc-pointer.json --shot-evalfile=scripts/paged-pointer-probe.js",
    "probe:statusbar": "electron --user-data-dir=C:/tmp/wc-probe-profile --disable-http-cache . --probe-out=/tmp/wc-statusbar.json --shot-evalfile=scripts/paged-statusbar-probe.js",
    "probe:overlays": "electron --user-data-dir=C:/tmp/wc-probe-profile --disable-http-cache . --probe-out=/tmp/wc-overlays.json --shot-evalfile=scripts/paged-overlays-probe.js",
    "probe:imageresize": "electron --user-data-dir=C:/tmp/wc-probe-profile --disable-http-cache . --probe-out=/tmp/wc-imageresize.json --shot-evalfile=scripts/paged-image-resize-probe.js",
    "probe:ink": "electron --user-data-dir=C:/tmp/wc-probe-profile --disable-http-cache . --probe-out=/tmp/wc-ink.json --shot-evalfile=scripts/paged-ink-probe.js",
    "probe:notes": "electron --user-data-dir=C:/tmp/wc-probe-profile --disable-http-cache . --probe-out=/tmp/wc-notes.json --shot-evalfile=scripts/paged-notes-probe.js",
    "probe:headerfooter": "electron --user-data-dir=C:/tmp/wc-probe-profile --disable-http-cache . --probe-out=/tmp/wc-hf.json --shot-evalfile=scripts/paged-headerfooter-probe.js",
    "probe:opennew": "electron --user-data-dir=C:/tmp/wc-probe-profile --disable-http-cache . --probe-out=/tmp/wc-opennew.json --shot-evalfile=scripts/paged-opennew-probe.js",
    "probe:columns": "electron --user-data-dir=C:/tmp/wc-probe-profile --disable-http-cache . --probe-out=/tmp/wc-columns.json --shot-evalfile=scripts/paged-columns-probe.js",
    "probe:linenumbers": "electron --user-data-dir=C:/tmp/wc-probe-profile --disable-http-cache . --probe-out=/tmp/wc-ln.json --shot-evalfile=scripts/paged-linenumbers-probe.js",
    "probe:hyphenation": "electron --user-data-dir=C:/tmp/wc-probe-profile --disable-http-cache . --probe-out=/tmp/wc-hyph.json --shot-evalfile=scripts/paged-hyphenation-probe.js"
  },
  "dependencies": {
    "@fluentui/svg-icons": "^1.1.328",
    "color2k": "^2.0.3",
    "dompurify": "^3.4.7",
    "he": "^1.2.0",
    "jszip": "^3.10.1",
    "lodash": "^4.17.21",
    "nspell": "^2.1.5",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-dropcursor": "^1.8.2",
    "prosemirror-gapcursor": "^1.4.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.7",
    "prosemirror-schema-basic": "^1.2.4",
    "prosemirror-state": "^1.4.4",
    "prosemirror-tables": "^1.8.5",
    "prosemirror-transform": "^1.12.0",
    "prosemirror-view": "^1.41.8",
    "rehype-parse": "^9.0.1",
    "rehype-remark": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "tippy.js": "^6.3.7",
    "unified": "^11.0.5",
    "utif2": "^4.1.0",
    "uuid": "^14.0.0",
    "vue": "^3.5.35",
    "xml-js": "^1.6.11",
    "y-prosemirror": "^1.3.7"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "electron": "^31.7.6",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.5"
  }
}
